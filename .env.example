DATABASE_URL=postgresql+asyncpg://hydration:hydration@localhost:5432/hydration

# ---- Camgenium Harvester (SoftSilicon Keycloak) -----------------------------
# The token endpoint and client id are baked in as defaults in config.py;
# only override if your tenant differs.
CAMGENIUM_BASE_URL=https://apisoftdev.l2s2.com
CAMGENIUM_TOKEN_URL=https://keycloaksoftdev.l2s2.com/realms/SoftSilicon/protocol/openid-connect/token
CAMGENIUM_CLIENT_ID=cg-harvester-public-api

# Long-lived refresh token issued by Keycloak (30-day lifetime).
# Backend exchanges this for short-lived access tokens on demand.
# Treat as a password. Leave blank to skip webhook registration in dev.
CAMGENIUM_REFRESH_TOKEN=

# Comma-separated Camgenium instrument identifiers to subscribe to.
# Empty means: skip webhook registration entirely (local dev mode).
CAMGENIUM_INSTRUMENT_IDS=

# Webhook delivery mode (0 / 1). Default 0 = raw forward.
CAMGENIUM_WEBHOOK_MODE=0

# Public URL Camgenium will POST measurements to.
# During a demo this is your `ngrok http 8000` URL.
PUBLIC_INGEST_URL=

# Shared secret Camgenium signs webhook deliveries with. The ingest
# endpoint skips verification entirely when this is blank or 'change-me',
# so fake_gateway.py works locally without any signing.
INGEST_SHARED_SECRET=change-me
